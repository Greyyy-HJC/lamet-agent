  ],
  "metadata": {
    "purpose": "physics",
    "analysis": {
      "gauge": "cg",
      "hadron": "pion",
      "channel": "qda"
    },
    "conventions": "Pion CG Collins-Soper kernel from qTMDWF. Uses cg_ratio renormalization (b=0 normalization + p=0 reference), imaginary zeroing before Fourier transform, and CS kernel extraction via multi-momentum simultaneous fit. Reference lattice setup matches pion_cg_tmdwf (a=0.06 fm, 48^3 x 64, HISQ Nf=3).",
    "setups": {
      "hisq_a06": {
        "lattice_action": "CG52bxyp20",
        "n_f": 3,
        "lattice_spacing_fm": 0.06,
        "spatial_extent": 48,
        "temporal_extent": 64,
        "pion_mass_valence_gev": 0.3,
        "pion_mass_sea_gev": 0.3
      }
    }
  },
  "kernel": {
    "callable_name": "identity_kernel",
    "source": "def identity_kernel(axis, values, metadata):\n    return values\n"
  },
  "workflow": {
    "stages": [
      "correlator_analysis",
      "renormalization",
      "fourier_transform",
      "evaluation"
    ],
    "stage_parameters": {
      "correlator_analysis": {
        "two_point": {
          "resampling": {
            "method": "jackknife",
            "bin_size": 1,
            "seed": 1984
          },
          "effective_mass": {
            "method": "solve"
          },
          "fit": {
            "enabled": true,
            "state_count": 2,
            "tmin": 3,
            "tmax": 11,
            "normalize": true
          }
        },
        "three_point": {
          "fit_modes": ["joint_ratio_fh"],
          "primary_fit_mode": "joint_ratio_fh",
          "joint_ratio_fh": {
            "fit_tsep": [3, 5, 7, 9],
            "tau_cut": 2
          },
          "sample_fit_workers": 8
        }
      },
      "renormalization": {
        "scheme": "cg_ratio"
      },
      "fourier_transform": {
        "gauge_type": "cg",
        "imaginary_sign": -1,
        "imaginary_zeroing": true,
        "separate_re_im": false,
        "sample_transform_workers": 8,
        "x_shift": 0.5,
        "physics": {
          "coordinate_direction": [1, 0, 0]
        },
        "x_grid": {
          "start": -2.0,
          "stop": 2.0,
          "num": 1000,
          "endpoint": false
        },
        "extrapolation": {
          "fit_idx_range": [9, 21],
          "extrapolated_length": 50.0,
          "weight_ini": 0.0,
          "m0_gev": 0.0,
          "joint_re_im_fit": true,
          "quark_sector": "valence"
        }
      },
      "evaluation": {
        "method": "cs_kernel_momentum_fit",
        "x_window": [0.3, 0.7],
        "fix_pz_gev": 1.62,
        "mu_renorm": 2.0,
        "csk_prior_mean": -0.5,
        "csk_prior_sigma": 1.0,
        "plot_ylim": [-3.0, 2.0],
        "literature_data_path": "../data/cs_kernel_literature_updated.gv"
      }
    }
  },
  "outputs": {
    "directory": "outputs/pion_cg_cs_kernel",
    "plot_formats": ["pdf"],
    "data_formats": ["csv", "json"],
    "keep_intermediates": true
  }
}
