{
  "goal": "custom",
  "correlators": [
    {
      "kind": "two_point",
      "path": "data/pion_2pt/two_point_raw_demo.txt",
      "file_format": "txt",
      "label": "pion_2pt_raw",
      "metadata": {
        "setup_id": "pion_demo",
        "momentum": [0, 0, 0],
        "smearing": "SS",
        "boundary": "periodic"
      }
    }
  ],
  "metadata": {
    "purpose": "physics",
    "analysis": {
      "gauge": "cg",
      "hadron": "pion",
      "channel": "qpdf"
    },
    "conventions": "Raw pion two-point analysis example.",
    "setups": {
      "pion_demo": {
        "lattice_action": "demo_periodic",
        "n_f": 2,
        "lattice_spacing_fm": 0.09,
        "spatial_extent": 32,
        "temporal_extent": 64,
        "pion_mass_valence_gev": 0.3,
        "pion_mass_sea_gev": 0.3
      }
    }
  },
  "kernel": {
    "callable_name": "identity_kernel",
    "source": "def identity_kernel(axis, values, metadata):\n    return values\n"
  },
  "workflow": {
    "stages": ["correlator_analysis"],
    "stage_parameters": {
      "correlator_analysis": {
        "two_point": {
          "boundary": "periodic",
          "resampling": {
            "method": "bootstrap",
            "sample_count": 100,
            "bin_size": 5,
            "seed": 1984
          },
          "effective_mass": {
            "method": "solve"
          },
          "fit": {
            "enabled": true,
            "state_count": 2,
            "tmin": 8,
            "tmax": 30,
            "normalize": true
          }
        }
      }
    }
  },
  "outputs": {
    "directory": "outputs/pion_2pt",
    "plot_formats": ["pdf"],
    "data_formats": ["csv", "json"],
    "keep_intermediates": true
  }
}
