  "metadata": {
    "ensemble": "demo-ensemble",
    "conventions": "toy-example",
    "matching_scale": 1.15,
    "kernel_width": 0.35
  },
  "kernel": {
    "callable_name": "demo_hard_kernel",
    "source": "import numpy as np\n\ndef demo_hard_kernel(momentum_axis, values, metadata):\n    scale = float(metadata.get('matching_scale', 1.0))\n    width = float(metadata.get('kernel_width', 0.25))\n    return scale * values / (1.0 + width * np.square(momentum_axis))\n"
  },
