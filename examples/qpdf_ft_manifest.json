{
  "goal": "custom",
  "correlators": [
    {
      "kind": "two_point",
      "path": "data/bare_qpdf/two_point_ss_p440.txt",
      "file_format": "txt",
      "label": "qpdf_ft_two_point",
      "metadata": {
        "Lt": 64,
        "ss_sp": "SS",
        "px": 4,
        "py": 4,
        "pz": 0
      }
    },
    {
      "kind": "three_point",
      "path": "data/bare_qpdf/three_point_ss_ud_gt_p440_b{b}_z{z:02d}.txt",
      "file_format": "txt",
      "label": "qpdf_ft_b{b}_z{z:02d}",
      "expand": {
        "b": [
          0
        ],
        "z": {
          "start": 0,
          "stop": 20
        }
      },
      "metadata": {
        "gamma": "gt",
        "flavor": "u-d",
        "px": 4,
        "py": 4,
        "pz": 0,
        "ss_sp": "SS"
      }
    }
  ],
  "metadata": {
    "ensemble": "proton-cg-pdf-p440",
    "conventions": "Sample-wise bare-qPDF to x-space qPDF Fourier-transform example at p=(4,4,0)"
  },
  "kernel": {
    "callable_name": "identity_kernel",
    "source": "def identity_kernel(axis, values, metadata):\n    return values\n"
  },
  "workflow": {
    "stages": [
      "correlator_analysis",
      "renormalization",
      "fourier_transform"
    ],
    "stage_parameters": {
      "correlator_analysis": {
        "two_point": {
          "temporal_extent": 64,
          "resampling": {
            "method": "jackknife",
            "bin_size": 1,
            "seed": 1984
          },
          "effective_mass": {
            "method": "solve"
          },
          "fit": {
            "enabled": true,
            "state_count": 2,
            "tmin": 4,
            "tmax": 13,
            "normalize": true
          },
          "bad_point_filter": {
            "mode": "mad",
            "mad_zcut": 8.0,
            "ratio_cut": 50.0,
            "replacement": "median"
          }
        },
        "three_point": {
          "fit_modes": [
            "joint_ratio_fh"
          ],
          "primary_fit_mode": "joint_ratio_fh",
          "ratio": {
            "fit_tsep": [
              8,
              9,
              10,
              11,
              12
            ],
            "tau_cut": 3
          },
          "fh": {
            "fit_tsep": [
              8,
              9,
              10,
              11,
              12
            ],
            "tau_cut": 3
          },
          "gamma": "gt",
          "flavor": "u-d",
          "b": 0,
          "bad_point_filter": {
            "mode": "mad",
            "mad_zcut": 8.0,
            "ratio_cut": 50.0,
            "replacement": "median"
          },
          "sample_fit_workers": 8
        }
      },
      "fourier_transform": {
        "family_selector": {
          "fit_mode": "joint_ratio_fh",
          "b": 0,
          "gamma": "gt",
          "flavor": "u-d",
          "ss_sp": "SS",
          "px": 4,
          "py": 4,
          "pz": 0
        },
        "gauge_type": "cg",
        "imaginary_sign": -1,
        "physics": {
          "lattice_spacing_fm": 0.09,
          "spatial_extent": 64,
          "momentum_vector": [
            4,
            4,
            0
          ],
          "coordinate_direction": [
            1,
            1,
            0
          ],
          "coordinate_step_multiplier": 1.4142135623730951
        },
        "x_grid": {
          "start": -1.9995,
          "stop": 2.0,
          "num": 4000,
          "endpoint": false
        },
        "extrapolation": {
          "fit_idx_range": [
            6,
            14
          ],
          "extrapolated_length": 100.0,
          "weight_ini": 0.0,
          "m0": 0.0
        }
      }
    }
  },
  "outputs": {
    "directory": "outputs/qpdf_ft",
    "plot_formats": [
      "pdf"
    ],
    "data_formats": [
      "csv",
      "json"
    ],
    "keep_intermediates": true
  }
}
