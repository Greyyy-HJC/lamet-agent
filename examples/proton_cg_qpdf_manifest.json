{
  "goal": "parton_distribution_function",
  "correlators": [
    {
      "kind": "two_point",
      "path": "data/proton_cg_qpdf/two_point_ss_p440.txt",
      "file_format": "txt",
      "label": "proton_cg_qpdf_two_point",
      "metadata": {
        "setup_id": "proton_p440",
        "momentum": [4, 4, 0],
        "smearing": "SS",
        "complex_samples": true
      }
    },
    {
      "kind": "three_point",
      "path": "data/proton_cg_qpdf/three_point_ss_ud_gt_p440_b{b}_z{z:02d}.txt",
      "file_format": "txt",
      "label": "proton_cg_qpdf_b{b}_z{z:02d}",
      "expand": {
        "b": [0],
        "z": {
          "start": 0,
          "stop": 20
        }
      },
      "metadata": {
        "setup_id": "proton_p440",
        "momentum": [4, 4, 0],
        "smearing": "SS",
        "displacement": {
          "b": "{b}",
          "z": "{z}"
        },
        "operator": {
          "gamma": "gt",
          "flavor": "u-d"
        }
      }
    }
  ],
  "metadata": {
    "purpose": "physics",
    "analysis": {
      "gauge": "cg",
      "hadron": "proton",
      "channel": "qpdf"
    },
    "conventions": "Canonical proton CG qPDF example using local raw TXT inputs.",
    "setups": {
      "proton_p440": {
        "lattice_action": "CG52bxyp30",
        "n_f": 3,
        "lattice_spacing_fm": 0.06,
        "spatial_extent": 48,
        "temporal_extent": 64,
        "pion_mass_valence_gev": 0.3,
        "pion_mass_sea_gev": 0.3
      }
    }
  },
  "kernel": {
    "callable_name": "identity_kernel",
    "source": "def identity_kernel(axis, values, metadata):\n    return values\n"
  },
  "workflow": {
    "stage_parameters": {
      "correlator_analysis": {
        "two_point": {
          "resampling": {
            "method": "jackknife",
            "bin_size": 1,
            "seed": 1984
          },
          "effective_mass": {
            "method": "solve"
          },
          "fit": {
            "enabled": true,
            "state_count": 2,
            "tmin": 4,
            "tmax": 13,
            "normalize": true
          },
          "bad_point_filter": {
            "mode": "mad",
            "mad_zcut": 8.0,
            "ratio_cut": 50.0,
            "replacement": "median"
          }
        },
        "three_point": {
          "fit_modes": ["joint_ratio_fh"],
          "primary_fit_mode": "joint_ratio_fh",
          "ratio": {
            "fit_tsep": [8, 9, 10, 11, 12],
            "tau_cut": 3
          },
          "fh": {
            "fit_tsep": [8, 9, 10, 11, 12],
            "tau_cut": 3
          },
          "bad_point_filter": {
            "mode": "mad",
            "mad_zcut": 8.0,
            "ratio_cut": 50.0,
            "replacement": "median"
          },
          "sample_fit_workers": 8
        }
      },
      "fourier_transform": {
        "family_selector": {
          "setup_id": "proton_p440",
          "fit_mode": "joint_ratio_fh",
          "b": 0,
          "gamma": "gt",
          "flavor": "u-d",
          "smearing": "SS"
        },
        "gauge_type": "cg",
        "imaginary_sign": -1,
        "separate_re_im": false,
        "physics": {
          "coordinate_direction": [1, 1, 0],
          "coordinate_step_multiplier": 1.4142135623730951
        },
        "x_grid": {
          "start": -1.9995,
          "stop": 1.9995,
          "num": 4000,
          "endpoint": true
        },
        "extrapolation": {
          "fit_idx_range": [6, 14],
          "extrapolated_length": 100.0,
          "weight_ini": 0.0,
          "m0": 0.0411522633744856
        }
      }
    }
  },
  "outputs": {
    "directory": "outputs/proton_cg_qpdf",
    "plot_formats": ["pdf"],
    "data_formats": ["csv", "json"],
    "keep_intermediates": true
  }
}
